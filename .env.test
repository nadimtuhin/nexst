# Test Environment Configuration

# Node Environment
NODE_ENV=test

# Application
PORT=3001
APP_NAME=nexst-test
APP_URL=http://localhost:3001

# API
API_PREFIX=/api
API_VERSION=v1

# Security
API_KEY=test-api-key-12345678901234567890
JWT_SECRET=test-jwt-secret-key-minimum-32-characters-long-12345678
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test-jwt-refresh-secret-key-minimum-32-characters-long-12345678
JWT_REFRESH_EXPIRES_IN=1d

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=1000

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# Logging
LOG_LEVEL=error
LOG_FILE_ENABLED=false
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=3d

# Database (for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/nexst_test
DATABASE_TYPE=postgres

# Redis (for future use)
REDIS_HOST=localhost
REDIS_PORT=6379

# Multi-Tenancy
MULTI_TENANT_ENABLED=false
