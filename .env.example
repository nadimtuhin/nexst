# Environment Configuration Example
# Copy this file to .env and update values as needed

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=development

# ============================================
# APPLICATION
# ============================================
PORT=3000
APP_NAME=nexst
APP_URL=http://localhost:3000

# ============================================
# API
# ============================================
API_PREFIX=/api
API_VERSION=v1

# ============================================
# SECURITY
# ============================================
# API Key for basic authentication (min 20 characters)
API_KEY=your-api-key-here-min-20-chars

# JWT Secret (min 32 characters) - CHANGE IN PRODUCTION
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=1h

# JWT Refresh Token (optional)
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-minimum-32-characters-long
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ============================================
# CORS
# ============================================
# Comma-separated list of allowed origins, or * for all
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# ============================================
# LOGGING
# ============================================
# Log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_FILE_MAX_SIZE=20m
LOG_FILE_MAX_FILES=14d

# ============================================
# DATABASE (for future use)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost:5432/nexst
DATABASE_TYPE=postgres

# ============================================
# REDIS (for future use)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# EMAIL (for future use)
# ============================================
# EMAIL_HOST=smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_USER=
# EMAIL_PASSWORD=
# EMAIL_FROM=noreply@example.com

# ============================================
# AWS (for future use)
# ============================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
