// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// To use PostgreSQL instead, change provider to "postgresql" and update DATABASE_URL:
// DATABASE_URL=postgresql://user:password@localhost:5432/nexst_dev

// ============================================
// User Model
// ============================================
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  age       Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

