// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// To use PostgreSQL instead, change provider to "postgresql" and update DATABASE_URL:
// DATABASE_URL=postgresql://user:password@localhost:5432/nexst_dev

// ============================================
// Enums
// ============================================
enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  MANAGE
}

enum PermissionResource {
  USER
  TENANT
  ROLE
  SETTINGS
  ANALYTICS
  ALL
}

// ============================================
// Tenant Model (Multi-Tenancy - Optional)
// ============================================
model Tenant {
  id        Int          @id @default(autoincrement())
  name      String
  slug      String       @unique
  domain    String?      @unique
  status    TenantStatus @default(ACTIVE)
  settings  String?      // JSON string for tenant-specific settings
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations
  users         User[]
  refreshTokens RefreshToken[]
  roles         Role[]         // RBAC: Tenant-specific roles
  userRoles     UserRole_New[] // RBAC: User role assignments within tenant

  @@map("tenants")
}

// ============================================
// User Model
// ============================================
model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  name          String
  password      String
  age           Int?
  role          UserRole       @default(USER)
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  tenantId      Int?           // Optional: for multi-tenancy support
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  tenant        Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  roles         UserRole_New[] // RBAC: User can have multiple roles

  @@index([tenantId])
  @@map("users")
}

// ============================================
// RefreshToken Model
// ============================================
model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  tenantId  Int?     // Optional: for multi-tenancy support
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([token])
  @@map("refresh_tokens")
}

// ============================================
// RBAC Models
// ============================================

// Permission: System-wide permissions (e.g., "users:create", "tenants:read")
model Permission {
  id          Int                @id @default(autoincrement())
  action      PermissionAction   // CREATE, READ, UPDATE, DELETE, MANAGE
  resource    PermissionResource // USER, TENANT, ROLE, SETTINGS, ANALYTICS, ALL
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Relations
  roles RolePermission[]

  @@unique([action, resource])
  @@map("permissions")
}

// Role: Tenant-scoped roles with custom permissions
model Role {
  id          Int      @id @default(autoincrement())
  name        String   // e.g., "Admin", "Editor", "Viewer"
  description String?
  tenantId    Int?     // Null = system-wide role, otherwise tenant-specific
  isSystem    Boolean  @default(false) // System roles can't be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRole_New[]

  @@unique([name, tenantId])
  @@index([tenantId])
  @@map("roles")
}

// RolePermission: Many-to-many relationship between roles and permissions
model RolePermission {
  id           Int      @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime @default(now())

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// UserRole_New: Many-to-many relationship between users and roles
model UserRole_New {
  id        Int      @id @default(autoincrement())
  userId    Int
  roleId    Int
  tenantId  Int?     // For tenant-scoped role assignments
  createdAt DateTime @default(now())

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, tenantId])
  @@index([userId])
  @@index([roleId])
  @@index([tenantId])
  @@map("user_roles")
}

